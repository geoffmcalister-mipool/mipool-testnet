{
  "name": "mipool-protocol",
  "version": "1.0.0",
  "description": "MiPool Protocol — Tokenised Mortgage Investment Pools on Avalanche",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "deploy:fuji": "hardhat run scripts/deploy.js --network fuji",
    "deploy:mainnet": "hardhat run scripts/deploy.js --network avalanche",
    "node": "hardhat node",
    "verify:fuji": "hardhat verify --network fuji",
    "gas": "REPORT_GAS=true hardhat test",
    "lint": "solhint 'contracts/**/*.sol'"
  },
  "dependencies": {},
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.0.0",
    "hardhat": "^2.22.0",
    "solhint": "^5.0.0"
  },
  "keywords": ["avalanche", "rwa", "mortgage", "defi", "tokenisation"],
  "author": "MiPool Protocol",
  "license": "MIT"
}
